<?xml version="1.0" encoding="utf-8"?>
<!--
  MelodyX Turntable Widget – 2×2 premium vinyl disc.
  Features:
  - Album art clipped in circle as the vinyl label
  - Slow rotation animation while playing (frame updates via WidgetArtStudio)
  - Tonearm overlay that moves onto the record when playing
  - Play/pause as a floating pill button
  - Like button with heart-burst state
  - Progress shown as thin accent arc ring around the disc
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@android:id/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:theme="@style/Theme.Widget.echomusic">

    <!-- Dynamic backdrop: blurred album art + palette scrim -->
    <ImageView
        android:id="@+id/widget_backdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:importantForAccessibility="no"
        android:contentDescription="@null" />

    <!-- Vinyl disc bitmap (full rendering from WidgetArtStudio.vinylDisc) -->
    <!-- Contains: grooved record + circular art label + progress arc + tonearm -->
    <ImageView
        android:id="@+id/widget_turntable_album_art"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:scaleType="fitCenter"
        android:contentDescription="@string/album_art" />

    <!-- Navigation controls – Top Right pill -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="34dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="8dp"
        android:orientation="horizontal"
        android:background="@drawable/widget_turntable_nav_bg"
        android:gravity="center_vertical"
        android:paddingStart="2dp"
        android:paddingEnd="2dp">

        <ImageButton
            android:id="@+id/widget_turntable_prev_button"
            android:layout_width="34dp"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_widget_skip_previous"
            android:contentDescription="@string/previous" />

        <ImageButton
            android:id="@+id/widget_turntable_next_button"
            android:layout_width="34dp"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_widget_skip_next"
            android:contentDescription="@string/next" />
    </LinearLayout>

    <!-- Like button – Top Left -->
    <FrameLayout
        android:id="@+id/widget_turntable_like_container"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_gravity="top|start"
        android:layout_marginTop="16dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/widget_turntable_nav_bg">
        <ImageButton
            android:id="@+id/widget_turntable_like_button"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_widget_heart_outline_nav"
            android:contentDescription="@string/like" />
    </FrameLayout>

    <!-- Play/Pause floating pill – Bottom Center -->
    <FrameLayout
        android:id="@+id/widget_turntable_play_container"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="12dp"
        android:background="@drawable/widget_turntable_play_bg">

        <ImageView
            android:id="@+id/widget_turntable_play_pause"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_widget_play_secondary"
            android:contentDescription="@string/play_pause" />
    </FrameLayout>
</FrameLayout>