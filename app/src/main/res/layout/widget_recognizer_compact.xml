<?xml version="1.0" encoding="utf-8"?>
<!--
  MelodyX Music Recognizer Widget – Compact (1×3).
  Smaller horizontal layout for narrow widget sizes.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@android:id/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:theme="@style/Theme.Widget.echomusic">

    <ImageView
        android:id="@+id/widget_backdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:importantForAccessibility="no"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <!-- Album art (visible only in SUCCESS state) -->
        <ImageView
            android:id="@+id/widget_recognizer_album_art"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:contentDescription="@string/album_art" />

        <!-- Text area -->
        <LinearLayout
            android:id="@+id/widget_recognizer_text_area"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="6dp">

            <TextView
                android:id="@+id/widget_recognizer_song_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/widget_text_primary"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="@string/widget_recognizer_tap_to_search" />

            <TextView
                android:id="@+id/widget_recognizer_artist_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="@color/widget_text_secondary"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="1dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Mic button -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp">
            <ImageView
                android:id="@+id/widget_recognizer_pulse"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/widget_mic_pulse_idle"
                android:contentDescription="@null" />
            <FrameLayout
                android:id="@+id/widget_recognizer_mic_container"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_gravity="center"
                android:background="@drawable/widget_mic_button_bg">
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_widget_mic"
                    android:contentDescription="@string/widget_recognizer_mic_desc" />
            </FrameLayout>
        </FrameLayout>
    </LinearLayout>
</FrameLayout>