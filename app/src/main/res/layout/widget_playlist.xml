<?xml version="1.0" encoding="utf-8"?>
<!--
  MelodyX Playlists Widget – 4×2 responsive.
  Top: mini player strip with album art, marquee title, prev/play/next/like controls.
  Bottom: 4 circular shortcut buttons with real artwork thumbnails
  (Playlists, Liked Songs, Downloads, My Top).
  Each shortcut uses artwork thumbnails or colorful gradient icons (no white glyphs).
  Labels use marquee to avoid truncation ("Downloaded songs" no longer clips).
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@android:id/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:theme="@style/Theme.Widget.echomusic">

    <!-- Dynamic backdrop -->
    <ImageView
        android:id="@+id/widget_backdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:importantForAccessibility="no"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <!-- ═══ Mini Player Strip ═══ -->
        <LinearLayout
            android:id="@+id/widget_playlist_player_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Album art -->
            <ImageView
                android:id="@+id/widget_playlist_album_art"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:scaleType="centerCrop"
                android:contentDescription="@string/album_art" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_playlist_song_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/not_playing"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/widget_text_primary"
                    android:maxLines="1"
                    android:ellipsize="marquee"
                    android:marqueeRepeatLimit="marquee_forever"
                    android:requiresFadingEdge="horizontal"
                    android:fadingEdgeLength="24dp" />

                <TextView
                    android:id="@+id/widget_playlist_artist_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:text="@string/choose_something_below"
                    android:textSize="11sp"
                    android:textColor="@color/widget_text_secondary"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <!-- Mini controls -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="4dp">

                <FrameLayout
                    android:id="@+id/widget_playlist_prev_container"
                    android:layout_width="30dp"
                    android:layout_height="30dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_widget_skip_previous"
                        android:contentDescription="@string/previous" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/widget_playlist_play_pause_container"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="2dp">
                    <ImageView
                        android:id="@+id/widget_playlist_play_bg"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/widget_circle_solid"
                        android:contentDescription="@null" />
                    <ImageView
                        android:id="@+id/widget_playlist_play_pause"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_widget_play"
                        android:contentDescription="@string/play_pause" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/widget_playlist_next_container"
                    android:layout_width="30dp"
                    android:layout_height="30dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_widget_skip_next"
                        android:contentDescription="@string/next" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginStart="2dp">
                    <ImageButton
                        android:id="@+id/widget_playlist_like_button"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="6dp"
                        android:scaleType="fitCenter"
                        android:background="@android:color/transparent"
                        android:src="@drawable/ic_widget_heart_outline_nav"
                        android:contentDescription="@string/like" />
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Progress bar -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginTop="8dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/widget_progress_track"
                android:scaleType="fitXY"
                android:contentDescription="@null" />
            <ImageView
                android:id="@+id/widget_playlist_progress_fill"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/widget_progress_clip"
                android:scaleType="fitXY"
                android:contentDescription="@null" />
        </FrameLayout>

        <!-- ═══ Shortcut Grid ═══ -->
        <LinearLayout
            android:id="@+id/widget_playlist_quick_picks_section"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="10dp"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Row 1 -->
            <LinearLayout
                android:id="@+id/widget_playlist_row_1"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="start"
                android:layout_marginBottom="6dp">

                <LinearLayout android:id="@+id/widget_playlist_card_1" style="@style/MelodyXPlaylistWidgetCard">
                    <FrameLayout style="@style/MelodyXPlaylistWidgetArtworkFrame">
                        <ImageView android:id="@+id/widget_playlist_card_1_art" style="@style/MelodyXPlaylistWidgetArtwork" android:contentDescription="@null" />
                        <FrameLayout android:id="@+id/widget_playlist_card_1_play_container" style="@style/MelodyXPlaylistWidgetCardPlayButton">
                            <ImageView android:id="@+id/widget_playlist_card_1_play" style="@style/MelodyXPlaylistWidgetCardPlayIcon" android:contentDescription="@null" />
                        </FrameLayout>
                    </FrameLayout>
                    <TextView android:id="@+id/widget_playlist_card_1_title" style="@style/MelodyXPlaylistWidgetCardTitle" />
                </LinearLayout>

                <LinearLayout android:id="@+id/widget_playlist_card_2" style="@style/MelodyXPlaylistWidgetCard">
                    <FrameLayout style="@style/MelodyXPlaylistWidgetArtworkFrame">
                        <ImageView android:id="@+id/widget_playlist_card_2_art" style="@style/MelodyXPlaylistWidgetArtwork" android:contentDescription="@null" />
                        <FrameLayout android:id="@+id/widget_playlist_card_2_play_container" style="@style/MelodyXPlaylistWidgetCardPlayButton">
                            <ImageView android:id="@+id/widget_playlist_card_2_play" style="@style/MelodyXPlaylistWidgetCardPlayIcon" android:contentDescription="@null" />
                        </FrameLayout>
                    </FrameLayout>
                    <TextView android:id="@+id/widget_playlist_card_2_title" style="@style/MelodyXPlaylistWidgetCardTitle" />
                </LinearLayout>

                <LinearLayout android:id="@+id/widget_playlist_card_3" style="@style/MelodyXPlaylistWidgetCard">
                    <FrameLayout style="@style/MelodyXPlaylistWidgetArtworkFrame">
                        <ImageView android:id="@+id/widget_playlist_card_3_art" style="@style/MelodyXPlaylistWidgetArtwork" android:contentDescription="@null" />
                        <FrameLayout android:id="@+id/widget_playlist_card_3_play_container" style="@style/MelodyXPlaylistWidgetCardPlayButton">
                            <ImageView android:id="@+id/widget_playlist_card_3_play" style="@style/MelodyXPlaylistWidgetCardPlayIcon" android:contentDescription="@null" />
                        </FrameLayout>
                    </FrameLayout>
                    <TextView android:id="@+id/widget_playlist_card_3_title" style="@style/MelodyXPlaylistWidgetCardTitle" />
                </LinearLayout>

                <LinearLayout android:id="@+id/widget_playlist_card_4" style="@style/MelodyXPlaylistWidgetCard">
                    <FrameLayout style="@style/MelodyXPlaylistWidgetArtworkFrame">
                        <ImageView android:id="@+id/widget_playlist_card_4_art" style="@style/MelodyXPlaylistWidgetArtwork" android:contentDescription="@null" />
                        <FrameLayout android:id="@+id/widget_playlist_card_4_play_container" style="@style/MelodyXPlaylistWidgetCardPlayButton">
                            <ImageView android:id="@+id/widget_playlist_card_4_play" style="@style/MelodyXPlaylistWidgetCardPlayIcon" android:contentDescription="@null" />
                        </FrameLayout>
                    </FrameLayout>
                    <TextView android:id="@+id/widget_playlist_card_4_title" style="@style/MelodyXPlaylistWidgetCardTitle" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:id="@+id/widget_playlist_row_2"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="start"
                android:visibility="gone">

                <LinearLayout android:id="@+id/widget_playlist_card_5" style="@style/MelodyXPlaylistWidgetCard">
                    <FrameLayout style="@style/MelodyXPlaylistWidgetArtworkFrame">
                        <ImageView android:id="@+id/widget_playlist_card_5_art" style="@style/MelodyXPlaylistWidgetArtwork" android:contentDescription="@null" />
                        <FrameLayout android:id="@+id/widget_playlist_card_5_play_container" style="@style/MelodyXPlaylistWidgetCardPlayButton">
                            <ImageView android:id="@+id/widget_playlist_card_5_play" style="@style/MelodyXPlaylistWidgetCardPlayIcon" android:contentDescription="@null" />
                        </FrameLayout>
                    </FrameLayout>
                    <TextView android:id="@+id/widget_playlist_card_5_title" style="@style/MelodyXPlaylistWidgetCardTitle" />
                </LinearLayout>

                <LinearLayout android:id="@+id/widget_playlist_card_6" style="@style/MelodyXPlaylistWidgetCard">
                    <FrameLayout style="@style/MelodyXPlaylistWidgetArtworkFrame">
                        <ImageView android:id="@+id/widget_playlist_card_6_art" style="@style/MelodyXPlaylistWidgetArtwork" android:contentDescription="@null" />
                        <FrameLayout android:id="@+id/widget_playlist_card_6_play_container" style="@style/MelodyXPlaylistWidgetCardPlayButton">
                            <ImageView android:id="@+id/widget_playlist_card_6_play" style="@style/MelodyXPlaylistWidgetCardPlayIcon" android:contentDescription="@null" />
                        </FrameLayout>
                    </FrameLayout>
                    <TextView android:id="@+id/widget_playlist_card_6_title" style="@style/MelodyXPlaylistWidgetCardTitle" />
                </LinearLayout>

                <LinearLayout android:id="@+id/widget_playlist_card_7" style="@style/MelodyXPlaylistWidgetCard">
                    <FrameLayout style="@style/MelodyXPlaylistWidgetArtworkFrame">
                        <ImageView android:id="@+id/widget_playlist_card_7_art" style="@style/MelodyXPlaylistWidgetArtwork" android:contentDescription="@null" />
                        <FrameLayout android:id="@+id/widget_playlist_card_7_play_container" style="@style/MelodyXPlaylistWidgetCardPlayButton">
                            <ImageView android:id="@+id/widget_playlist_card_7_play" style="@style/MelodyXPlaylistWidgetCardPlayIcon" android:contentDescription="@null" />
                        </FrameLayout>
                    </FrameLayout>
                    <TextView android:id="@+id/widget_playlist_card_7_title" style="@style/MelodyXPlaylistWidgetCardTitle" />
                </LinearLayout>

                <LinearLayout android:id="@+id/widget_playlist_card_8" style="@style/MelodyXPlaylistWidgetCard">
                    <FrameLayout style="@style/MelodyXPlaylistWidgetArtworkFrame">
                        <ImageView android:id="@+id/widget_playlist_card_8_art" style="@style/MelodyXPlaylistWidgetArtwork" android:contentDescription="@null" />
                        <FrameLayout android:id="@+id/widget_playlist_card_8_play_container" style="@style/MelodyXPlaylistWidgetCardPlayButton">
                            <ImageView android:id="@+id/widget_playlist_card_8_play" style="@style/MelodyXPlaylistWidgetCardPlayIcon" android:contentDescription="@null" />
                        </FrameLayout>
                    </FrameLayout>
                    <TextView android:id="@+id/widget_playlist_card_8_title" style="@style/MelodyXPlaylistWidgetCardTitle" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>