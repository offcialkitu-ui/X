<?xml version="1.0" encoding="utf-8"?>
<!--
  MelodyX Music Player – Compact Wide (4×1).
  Used via viewMapping when widget is wide but short (minWidth >= 180 && minHeight < 100).
  Shows album art + title + artist + play/like controls in a horizontal bar.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@android:id/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:theme="@style/Theme.Widget.echomusic">

    <!-- Backdrop -->
    <ImageView
        android:id="@+id/widget_backdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:importantForAccessibility="no"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <!-- Small rounded album art -->
        <ImageView
            android:id="@+id/widget_wide_album_art"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:scaleType="centerCrop"
            android:contentDescription="@string/album_art" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="6dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_wide_song_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/not_playing"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="marquee"
                android:marqueeRepeatLimit="marquee_forever"
                android:requiresFadingEdge="horizontal"
                android:fadingEdgeLength="24dp"
                android:textColor="@color/widget_text_primary" />

            <TextView
                android:id="@+id/widget_wide_artist_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/widget_text_secondary" />
        </LinearLayout>

        <!-- Play/Pause circle -->
        <FrameLayout
            android:id="@+id/widget_wide_play_container"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="4dp">

            <ImageView
                android:id="@+id/widget_wide_play_bg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/widget_circle_solid"
                android:contentDescription="@null" />

            <ImageView
                android:id="@+id/widget_wide_play_pause"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_widget_play_low"
                android:contentDescription="@string/play_pause" />
        </FrameLayout>

        <!-- Like button -->
        <ImageButton
            android:id="@+id/widget_wide_like_button"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_widget_heart_outline_nav"
            android:contentDescription="@string/like" />
    </LinearLayout>
</FrameLayout>