<?xml version="1.0" encoding="utf-8"?>
<!--
  MelodyX Playlists Widget – 4×2 responsive.
  Top: mini player strip with album art, marquee title, controls.
  Bottom: 4 circular shortcut buttons with real artwork thumbnails.
  Android 12+ features: previewLayout, description, widgetCategory,
  targetCellWidth/Height, and resizeMode.
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="250dp"
    android:minHeight="220dp"
    android:minResizeWidth="160dp"
    android:minResizeHeight="180dp"
    android:maxResizeWidth="520dp"
    android:maxResizeHeight="440dp"
    android:updatePeriodMillis="0"
    android:previewLayout="@layout/widget_playlist_preview"
    android:initialLayout="@layout/widget_playlist"
    android:description="@string/widget_playlists_description"
    android:widgetCategory="home_screen"
    android:resizeMode="horizontal|vertical"
    android:targetCellWidth="4"
    android:targetCellHeight="2" />