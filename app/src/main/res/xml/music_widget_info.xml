<?xml version="1.0" encoding="utf-8"?>
<!--
  MelodyX Music Player Widget – responsive 4×2 / 4×1 / 2×2.
  Android 12+ features: previewLayout, description, widgetCategory,
  targetCellWidth/Height, and resizeMode for all orientations.
  Uses viewMapping via RemoteViews for size-responsive layouts.
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="220dp"
    android:minHeight="80dp"
    android:minResizeWidth="140dp"
    android:minResizeHeight="70dp"
    android:maxResizeWidth="520dp"
    android:maxResizeHeight="280dp"
    android:updatePeriodMillis="0"
    android:previewLayout="@layout/widget_music_player"
    android:initialLayout="@layout/widget_music_player"
    android:description="@string/widget_music_player_description"
    android:widgetCategory="home_screen"
    android:resizeMode="horizontal|vertical"
    android:targetCellWidth="4"
    android:targetCellHeight="2" />