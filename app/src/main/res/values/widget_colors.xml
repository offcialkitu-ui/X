<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
     Widget colour tokens for MelodyX.
     Android 12+ (API 31+): system_accent1_* pulls the user's wallpaper tint (Material You).
     Below API 31: hardcoded fallback values (brand red #E53935 / neutral surfaces).
    -->

    <!-- ─── Text ────────────────────────────────────────────────────────────── -->
    <!-- Primary text (song title, labels) – light theme -->
    <color name="widget_text_primary">#FF1C1B1F</color>
    <!-- Secondary text (artist name, timestamps) – light theme -->
    <color name="widget_text_secondary">#FF49454F</color>

    <!-- ─── Dynamic Color fallback (< API 31) ──────────────────────────────── -->
    <color name="widget_accent">#FFE53935</color>
    <color name="widget_on_accent">#FFFFFFFF</color>

    <color name="widget_backdrop_start">#FFFEF7FF</color>
    <color name="widget_backdrop_end">#FFF3EDF7</color>

    <!-- ─── Control surfaces ───────────────────────────────────────────────── -->
    <color name="widget_control_surface">#33FFFFFF</color>
    <color name="widget_play_bg">#FFEADDFF</color>
    <color name="widget_play_icon">#FF21005D</color>

    <!-- ─── Recognizer ─────────────────────────────────────────────────────── -->
    <color name="widget_mic_active_bg">#FF7965AF</color>
    <color name="widget_mic_pulse_ring">#994F378B</color>
    <color name="widget_mic_pulse_ring_mid">#664F378B</color>
    <color name="widget_mic_pulse_ring_low">#334F378B</color>
    <color name="widget_mic_pulse_ring_fade">#004F378B</color>

    <!-- ─── Premium widget surfaces ────────────────────────────────────────── -->
    <color name="widget_scrim_start">#80000000</color>
    <color name="widget_scrim_end">#CC000000</color>
    <color name="widget_tonal_surface">#1AFFFFFF</color>
    <color name="widget_tonal_surface_dark">#1A000000</color>
    <color name="widget_heart_active">#FFE53935</color>
    <color name="widget_heart_inactive">#B0FFFFFF</color>

    <!-- ─── Android 12+ system accent references (set via code) ────────────── -->
    <!-- These are resolved at runtime via context.getColor(android.R.color.system_accent1_*) -->
</resources>